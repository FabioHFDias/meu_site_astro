      let userLocation = null;

      const mockNotifications = [
        { id: 1, type: 'alert', title: 'Veículo parado há +48h', desc: 'Placa ABC-1234 sem sinal desde ontem', time: '2 min atrás', read: false },
        { id: 2, type: 'success', title: 'Equipamento vinculado', desc: 'IMEI 865190072028015 vinculado com sucesso', time: '15 min atrás', read: false },
        { id: 3, type: 'info', title: 'Nova empresa cadastrada', desc: 'Altis Tec foi adicionada ao sistema', time: '1h atrás', read: false },
        { id: 4, type: 'warning', title: 'Manutenção programada', desc: 'Servidor será reiniciado às 03:00', time: '3h atrás', read: true }
      ];

      document.addEventListener('DOMContentLoaded', () => {
        initSidebar();
        initCompanyDropdown();
        initModals();
        initHeaderControls();
        initRadarDeVendas();
        changePage('inicio');
      });

      // --- RADAR DE VENDAS ---
      function initRadarDeVendas() {
        const btnSearch = document.getElementById('btn-search-prospects');
        const btnMyLocation = document.getElementById('btn-my-location');
        const btnExport = document.getElementById('btn-export-results');

        if(btnSearch) btnSearch.addEventListener('click', searchProspects);
        if(btnMyLocation) btnMyLocation.addEventListener('click', getMyLocation);
        if(btnExport) btnExport.addEventListener('click', exportResults);
      }

      async function searchProspects() {
        const radius = document.getElementById('search-radius').value || 2;
        const category = document.getElementById('search-category').value;
        const nameFilter = document.getElementById('search-name').value;
        
        const btn = document.getElementById('btn-search-prospects');
        btn.classList.add('btn-loading');
        
        try {
          // Buscar empresas reais do banco
          let empresas = await fetchEmpresas();
          
          if (nameFilter) {
            empresas = empresas.filter(e => 
              e.nomeFantasia.toLowerCase().includes(nameFilter.toLowerCase()) ||
              e.razaoSocial.toLowerCase().includes(nameFilter.toLowerCase())
            );
          }

          // Simula filtro por categoria
          if (category) {
            empresas = empresas.filter(() => Math.random() > 0.5);
          }

          radarResults = empresas;
          renderRadarResults(empresas, radius);
          showToast(`Encontradas ${empresas.length} empresas no raio de ${radius}km`);
        } catch (err) {
          showToast('Erro ao buscar prospects', 'error');
        } finally {
          btn.classList.remove('btn-loading');
        }
      }

      function renderRadarResults(empresas, radius) {
        const list = document.getElementById('radar-results-list');
        const count = document.getElementById('results-count');
        const total = document.getElementById('radar-total');
        
        count.textContent = empresas.length;
        total.textContent = empresas.length;

        if (empresas.length === 0) {
          list.innerHTML = `
            <div class="p-8 text-center text-slate-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <p class="text-sm">Nenhuma empresa encontrada</p>
            </div>`;
          return;
        }

        list.innerHTML = empresas.map((emp, idx) => {
          const distance = (Math.random() * radius).toFixed(2); 
          return `
            <div class="radar-result-item p-4 border-b border-slate-800 cursor-pointer" onclick="focusOnResult(${idx})">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <h4 class="text-sm font-medium text-white truncate">${emp.nomeFantasia}</h4>
                  <p class="text-xs text-slate-400 mt-0.5">${emp.razaoSocial || 'Razão Social não informada'}</p>
                  <div class="flex items-center gap-2 mt-2">
                    <span class="text-xs text-slate-500 flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                      ${distance} km
                    </span>
                    <span class="text-xs text-slate-500">${emp.subdominio || 'Endereço não informado'}</span>
                  </div>
                </div>
                <button class="px-3 py-1.5 bg-blue-600/20 text-blue-400 rounded-lg text-xs font-medium hover:bg-blue-600/30 transition-colors" onclick="event.stopPropagation(); contactCompany('${emp._id}')">
                  Contatar
                </button>
              </div>
            </div>
          `;
        }).join('');

        updateRadarMap(empresas, radius);
      }

      function updateRadarMap(empresas, radius) {
        if (!radarMap) return;
        radarMarkers.forEach(m => radarMap.removeLayer(m));
        radarMarkers = [];

        if (userLocation) {
          const circle = L.circle([userLocation.lat, userLocation.lng], {
            radius: radius * 1000,
            color: '#3b82f6',
            fillColor: '#3b82f6',
            fillOpacity: 0.1,
            dashArray: '5,5'
          }).addTo(radarMap);
          radarMarkers.push(circle);
        }

        empresas.forEach((emp) => {
          const lat = userLocation ? userLocation.lat + (Math.random() - 0.5) * 0.02 : -22.9068 + (Math.random() - 0.5) * 0.02;
          const lng = userLocation ? userLocation.lng + (Math.random() - 0.5) * 0.02 : -43.1729 + (Math.random() - 0.5) * 0.02;
          
          const marker = L.marker([lat, lng])
            .addTo(radarMap)
            .bindPopup(`<b>${emp.nomeFantasia}</b><br>${emp.razaoSocial || ''}`);
          
          radarMarkers.push(marker);
        });

        if (empresas.length > 0) {
          const firstLat = userLocation ? userLocation.lat : -22.9068;
          const firstLng = userLocation ? userLocation.lng : -43.1729;
          radarMap.setView([firstLat, firstLng], 13);
        }
      }

      function getMyLocation() {
        const btn = document.getElementById('btn-my-location');
        btn.classList.add('btn-loading');
        
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (position) => {
              userLocation = { lat: position.coords.latitude, lng: position.coords.longitude };
              if (radarMap) {
                radarMap.setView([userLocation.lat, userLocation.lng], 13);
                L.marker([userLocation.lat, userLocation.lng]).addTo(radarMap).bindPopup('Sua localização').openPopup();
              }
              showToast('Localização atualizada com sucesso');
              btn.classList.remove('btn-loading');
            },
            (error) => {
              showToast('Erro ao obter localização: ' + error.message, 'error');
              btn.classList.remove('btn-loading');
            }
          );
        } else {
          showToast('Geolocalização não suportada pelo navegador', 'error');
          btn.classList.remove('btn-loading');
        }
      }

      function exportResults() {
        if (radarResults.length === 0) {
          showToast('Nenhum resultado para exportar', 'error');
          return;
        }
        const csv = [
          ['Nome Fantasia', 'Razão Social', 'Subdomínio'].join(','),
          ...radarResults.map(e => [e.nomeFantasia, e.razaoSocial, e.subdominio || ''].join(','))
        ].join('\n');
        
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `radar-vendas-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
        showToast('Resultados exportados com sucesso');
      }

      window.focusOnResult = function(idx) {
        if (radarMarkers[idx + 1]) { 
          radarMap.flyTo(radarMarkers[idx + 1].getLatLng(), 16);
          radarMarkers[idx + 1].openPopup();
        }
      };

      window.contactCompany = function(id) {
        showToast('Funcionalidade de contato em desenvolvimento');
      };

      // --- HEADER CONTROLS ---
      function initHeaderControls() {
        const themeToggle = document.getElementById('theme-toggle');
        const moonIcon = document.getElementById('moon-icon');
        const sunIcon = document.getElementById('sun-icon');
        const html = document.documentElement;

        const savedTheme = localStorage.getItem('theme') || 'dark';
        if (savedTheme === 'light') {
          html.classList.remove('dark');
          moonIcon.classList.add('hidden');
          sunIcon.classList.remove('hidden');
        }

        themeToggle.addEventListener('click', () => {
          html.classList.toggle('dark');
          const isDark = html.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          moonIcon.classList.toggle('hidden', !isDark);
          sunIcon.classList.toggle('hidden', isDark);
        });

        const notifBtn = document.getElementById('notif-btn');
        const notifDropdown = document.getElementById('notif-dropdown');
        const notifList = document.getElementById('notif-list');
        const markAllRead = document.getElementById('mark-all-read');

        function renderNotifications() {
          const unreadCount = mockNotifications.filter(n => !n.read).length;
          const badge = document.getElementById('notif-badge');
          badge.textContent = unreadCount;
          badge.style.display = unreadCount > 0 ? 'flex' : 'none';

          notifList.innerHTML = mockNotifications.map(n => {
            const iconColor = n.type === 'alert' ? 'text-red-400 bg-red-400/10' 
              : n.type === 'success' ? 'text-emerald-400 bg-emerald-400/10'
              : n.type === 'warning' ? 'text-amber-400 bg-amber-400/10'
              : 'text-blue-400 bg-blue-400/10';
            const icon = n.type === 'alert' ? '!' : n.type === 'success' ? '✓' : n.type === 'warning' ? '⚠' : 'ℹ';
            return `
              <div class="dropdown-item px-4 py-3 ${n.read ? 'opacity-60' : ''}" onclick="readNotification(${n.id})">
                <div class="w-8 h-8 rounded-full ${iconColor} flex items-center justify-center shrink-0 text-sm font-bold">${icon}</div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium ${n.read ? 'text-slate-400' : 'text-white'} truncate">${n.title}</p>
                  <p class="text-xs text-slate-500 truncate">${n.desc}</p>
                </div>
                <span class="text-xs text-slate-500 whitespace-nowrap ml-2">${n.time}</span>
              </div>
            `;
          }).join('');
        }

        window.readNotification = function(id) {
          const notif = mockNotifications.find(n => n.id === id);
          if (notif) { notif.read = true; renderNotifications(); }
        };

        markAllRead.addEventListener('click', () => {
          mockNotifications.forEach(n => n.read = true);
          renderNotifications();
          showToast('Todas notificações marcadas como lidas');
        });

        notifBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = !notifDropdown.classList.contains('hidden');
          document.getElementById('profile-dropdown').classList.add('hidden');
          document.getElementById('profile-dropdown').classList.remove('open');
          
          if (isOpen) {
            notifDropdown.classList.add('hidden');
            notifDropdown.classList.remove('open');
          } else {
            renderNotifications();
            notifDropdown.classList.remove('hidden');
            notifDropdown.classList.add('open');
          }
        });

        const profileBtn = document.getElementById('profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');

        profileBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = !profileDropdown.classList.contains('hidden');
          notifDropdown.classList.add('hidden');
          notifDropdown.classList.remove('open');
          
          if (isOpen) {
            profileDropdown.classList.add('hidden');
            profileDropdown.classList.remove('open');
          } else {
            profileDropdown.classList.remove('hidden');
            profileDropdown.classList.add('open');
          }
        });

        document.addEventListener('click', (e) => {
          if (!notifBtn.contains(e.target) && !notifDropdown.contains(e.target)) {
            notifDropdown.classList.add('hidden');
            notifDropdown.classList.remove('open');
          }
          if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
            profileDropdown.classList.add('hidden');
            profileDropdown.classList.remove('open');
          }
        });
      }

      function handleLogout() {
        if (confirm('Deseja realmente sair do sistema?')) {
          showToast('Sessão encerrada com sucesso');
          setTimeout(() => { alert('Redirecionar para tela de login'); }, 1000);
        }
      }

      // --- TOAST SYSTEM ---
      function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const bg = type === 'success' ? 'bg-emerald-600' : 'bg-red-600';
        const icon = type === 'success' 
          ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>'
          : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>';
        
        toast.className = `${bg} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-3 text-sm font-medium pointer-events-auto toast-enter`;
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(100%)';
          toast.style.transition = 'all 0.3s ease';
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      }

      // --- SIDEBAR ---
      function initSidebar() {
        const toggle = document.getElementById('sidebar-toggle');
        const sidebar = document.querySelector('.sidebar-container');
        const mainContent = document.getElementById('main-content');
        const railIcon = document.querySelector('.rail-icon');
        
        toggle.addEventListener('click', () => {
          sidebar.classList.toggle('collapsed');
          mainContent.classList.toggle('ml-72');
          mainContent.classList.toggle('ml-20');
          if (railIcon) railIcon.style.transform = sidebar.classList.contains('collapsed') ? 'rotate(180deg)' : 'rotate(0deg)';
        });
      }

      // --- COMPANY DROPDOWN ---
      function initCompanyDropdown() {
        const btn = document.getElementById('company-selector-btn');
        const dropdown = document.getElementById('company-dropdown');
        const arrow = document.getElementById('company-arrow');
        const list = document.getElementById('company-list');
        const search = document.getElementById('company-search');

        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const isOpen = dropdown.classList.contains('open');
          if (isOpen) {
            dropdown.classList.remove('open');
            arrow.style.transform = 'rotate(0deg)';
            btn.classList.remove('active');
          } else {
            dropdown.classList.add('open');
            arrow.style.transform = 'rotate(180deg)';
            btn.classList.add('active');
            const empresas = await fetchEmpresas();
            renderCompanyList(empresas, search.value);
            setTimeout(() => search.focus(), 100);
          }
        });

        search.addEventListener('input', async (e) => {
          const empresas = await fetchEmpresas();
          renderCompanyList(empresas, e.target.value);
        });

        document.addEventListener('click', (e) => {
          if (dropdown && !dropdown.contains(e.target) && !btn.contains(e.target)) {
            dropdown.classList.remove('open');
            arrow.style.transform = 'rotate(0deg)';
            btn.classList.remove('active');
          }
        });
      }

      async function fetchEmpresas() {
        try {
          const res = await fetch('/api/empresa');
          const data = await res.json();
          return data.error ? [] : data;
        } catch (err) { return []; }
      }

      function renderCompanyList(empresas, filter) {
        const list = document.getElementById('company-list');
        if (!list) return;
        const filtered = filter ? empresas.filter(e => e.nomeFantasia.toLowerCase().includes(filter.toLowerCase())) : empresas;
        if (filtered.length === 0) {
          list.innerHTML = '<div class="px-4 py-3 text-sm text-slate-500 text-center">Nenhuma empresa encontrada</div>';
          return;
        }
        let html = `<div class="company-item ${!empresaAtiva ? 'active' : ''}" onclick="selectCompany(null)">
          <div class="w-8 h-8 rounded bg-slate-700 flex items-center justify-center shrink-0"><span class="text-xs text-white">T</span></div>
          <div class="flex-1"><div class="text-sm font-medium text-white">Todas as Empresas</div></div>
        </div>`;
        filtered.forEach(emp => {
          const id = emp._id.$oid || emp._id;
          const initials = emp.nomeFantasia.substring(0, 2).toUpperCase();
          const isActive = empresaAtiva && (empresaAtiva._id === id || empresaAtiva._id.$oid === id);
          html += `<div class="company-item ${isActive ? 'active' : ''}" onclick="selectCompany(${JSON.stringify(emp).replace(/"/g, '&quot;')})">
            <div class="w-8 h-8 rounded bg-red-600 flex items-center justify-center shrink-0"><span class="text-xs text-white">${initials}</span></div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-white truncate">${emp.nomeFantasia}</div>
              <div class="text-xs text-slate-400 truncate">${emp.razaoSocial}</div>
            </div>
          </div>`;
        });
        list.innerHTML = html;
      }

      window.selectCompany = function(emp) {
        empresaAtiva = emp;
        const btn = document.getElementById('company-selector-btn');
        const nameSpan = btn.querySelector('.truncate');
        const avatar = btn.querySelector('.w-8');
        if (emp) {
          nameSpan.textContent = emp.nomeFantasia;
          avatar.innerHTML = `<span class="text-xs text-white">${emp.nomeFantasia.substring(0, 2).toUpperCase()}</span>`;
        } else {
          nameSpan.textContent = "Empresas...";
          avatar.innerHTML = `<span class="text-xs font-bold text-white">T</span>`;
        }
        document.getElementById('company-dropdown').classList.remove('open');
        document.getElementById('company-arrow').style.transform = 'rotate(0deg)';
        btn.classList.remove('active');
        if (currentPage === 'inicio') updateDashboard();
        else if (currentPage === 'radar') searchProspects();
        else renderTable(currentPage);
      };

      // --- NAVIGATION ---
      window.changePage = function(page) {
        currentPage = page;
        const config = pagesConfig[page];
        
        document.querySelectorAll('.nav-item, .rail-btn').forEach(el => {
          if (el.dataset.tab === page || el.dataset.target === page) {
            el.classList.add('active', 'bg-red-600/10', 'text-red-500');
            el.classList.remove('text-slate-400');
          } else {
            el.classList.remove('active', 'bg-red-600/10', 'text-red-500');
            el.classList.add('text-slate-400');
          }
        });

        const dashView = document.getElementById('dashboard-view');
        const listView = document.getElementById('list-view');
        const radarView = document.getElementById('radar-view');

        if (config.isDashboard) {
          dashView.classList.remove('hidden');
          listView.classList.add('hidden');
          radarView.classList.add('hidden');
          setTimeout(() => { initMap(); updateDashboard(); }, 100);
        } else if (config.isRadar) {
          dashView.classList.add('hidden');
          listView.classList.add('hidden');
          radarView.classList.remove('hidden');
          setTimeout(() => { initRadarMap(); }, 100);
        } else {
          dashView.classList.add('hidden');
          listView.classList.remove('hidden');
          radarView.classList.add('hidden');
          document.getElementById('btn-add-text').textContent = `Adicionar ${config.title.slice(0, -1)}`;
          renderTable(page);
        }
      };

      document.querySelectorAll('.nav-item, .rail-btn').forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          changePage(item.dataset.tab || item.dataset.target);
        });
      });

      // --- TABLE RENDERING ---
      async function renderTable(type) {
        const tbody = document.getElementById('table-body');
        const thead = document.getElementById('table-header');
        tbody.innerHTML = '<tr><td colspan="5" class="p-8 text-center text-slate-400">Carregando...</td></tr>';
        const config = pagesConfig[type];
        try {
          let items = await fetch(`/api/${config.apiName}`).then(r => r.json());
          items = items.error ? [] : items;
          if (empresaAtiva) {
            const empId = empresaAtiva._id.$oid || empresaAtiva._id;
            items = items.filter(i => i.empresaId === empId);
          }
          document.getElementById('total-items').textContent = items.length;
          const headers = type === 'empresa' ? ['Nome Fantasia', 'Razão Social', 'Status', 'Ações'] 
            : type === 'equipamento' ? ['IMEI', 'Modelo', 'Status', 'Ações']
            : ['Placa', 'Modelo', 'Proprietário', 'Ações'];
          thead.innerHTML = `<tr>${headers.map(h => `<th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">${h}</th>`).join('')}</tr>`;
          if (items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="p-8 text-center text-slate-400">Nenhum registro encontrado.</td></tr>';
            return;
          }
          tbody.innerHTML = items.map(item => {
            const id = item._id.$oid || item._id;
            let rowContent = '';
            if (type === 'empresa') {
              rowContent = `<td class="px-6 py-4 text-white">${item.nomeFantasia}</td><td class="px-6 py-4 text-slate-400">${item.razaoSocial}</td><td class="px-6 py-4"><span class="px-2 py-1 rounded-full text-xs ${item.status ? 'bg-emerald-500/10 text-emerald-400' : 'bg-red-500/10 text-red-400'}">${item.status ? 'Ativo' : 'Inativo'}</span></td>`;
            } else if (type === 'equipamento') {
              rowContent = `<td class="px-6 py-4 font-mono text-white">${item.imei}</td><td class="px-6 py-4 text-slate-400">${item.modelo}</td><td class="px-6 py-4"><span class="px-2 py-1 rounded-full text-xs ${item.status === 'Livre' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-blue-500/10 text-blue-400'}">${item.status}</span></td>`;
            } else {
              rowContent = `<td class="px-6 py-4 font-mono text-white">${item.placa}</td><td class="px-6 py-4 text-slate-400">${item.marca} ${item.modelo}</td><td class="px-6 py-4 text-slate-400">${item.proprietario || '-'}</td>`;
            }
            rowContent += `<td class="px-6 py-4"><div class="flex items-center gap-2">
              <button onclick="editItem('${type}', '${id}')" class="text-blue-400 hover:text-blue-300 p-1 transition-colors" title="Editar"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></button>
              <button onclick="deleteItem('${type}', '${id}')" class="text-red-400 hover:text-red-300 p-1 transition-colors" title="Excluir"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></button>
            </div></td>`;
            return `<tr class="hover:bg-slate-800/50 transition-colors">${rowContent}</tr>`;
          }).join('');
        } catch (err) {
          tbody.innerHTML = '<tr><td colspan="5" class="p-8 text-center text-red-400">Erro ao carregar dados.</td></tr>';
        }
      }

      // --- MODAL & FORM LOGIC ---
      function initModals() {
        const modal = document.getElementById('modal');
        const deleteModal = document.getElementById('delete-modal');
        
        document.querySelector('.close')?.addEventListener('click', () => closeModal());
        document.getElementById('modal-cancel')?.addEventListener('click', () => closeModal());
        document.getElementById('cancel-delete')?.addEventListener('click', () => closeDeleteModal());
        
        modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
        deleteModal?.addEventListener('click', (e) => { if (e.target === deleteModal) closeDeleteModal(); });
        
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') { closeModal(); closeDeleteModal(); }
        });
      }

      function closeModal() {
        const modal = document.getElementById('modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.getElementById('modal-form').reset();
        document.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));
      }

      function openDeleteModal(type, id) {
        pendingDelete = { type, id };
        const modal = document.getElementById('delete-modal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }

      function closeDeleteModal() {
        const modal = document.getElementById('delete-modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        pendingDelete = null;
      }

      document.getElementById('confirm-delete')?.addEventListener('click', async () => {
        if (!pendingDelete) return;
        const btn = document.getElementById('confirm-delete');
        btn.classList.add('btn-loading');
        try {
          await fetch(`/api/${pagesConfig[pendingDelete.type].apiName}`, {
            method: 'DELETE',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({_id: pendingDelete.id})
          });
          closeDeleteModal();
          renderTable(pendingDelete.type);
          showToast('Registro excluído com sucesso');
        } catch (err) {
          showToast('Erro ao excluir', 'error');
        } finally {
          btn.classList.remove('btn-loading');
        }
      });

      window.deleteItem = function(type, id) { openDeleteModal(type, id); };

      window.editItem = async function(type, id) {
        const items = await fetch(`/api/${pagesConfig[type].apiName}`).then(r => r.json());
        const item = items.find(i => (i._id.$oid || i._id) === id);
        if (item) openModal(type, item);
      };

      document.getElementById('btn-add').addEventListener('click', () => openModal(currentPage));

      async function openModal(type, item = null) {
        const config = pagesConfig[type];
        document.getElementById('modal-title').textContent = item ? `Editar ${config.title.slice(0, -1)}` : `Adicionar ${config.title.slice(0, -1)}`;
        document.getElementById('modal-item-id').value = item ? (item._id.$oid || item._id) : '';
        document.getElementById('modal-submit-text').textContent = item ? 'Salvar Alterações' : 'Salvar';
        
        const fieldsContainer = document.getElementById('modal-fields');
        let html = '';

        if (type !== 'empresa') {
          const empresas = await fetchEmpresas();
          html += `<div class="col-span-1 md:col-span-2"><label class="block text-sm font-medium text-slate-300 mb-1.5">Empresa Vinculada</label>
            <select name="empresaId" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2.5 text-white focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition-all" required>
              <option value="">Selecione uma empresa...</option>
              ${empresas.map(e => `<option value="${e._id.$oid || e._id}" ${item && item.empresaId === (e._id.$oid || e._id) ? 'selected' : ''}>${e.nomeFantasia}</option>`).join('')}
            </select>
            <p class="error-msg">Selecione uma empresa</p>
          </div>`;
        }

        config.fields.forEach(f => {
          const isRequired = config.required.includes(f);
          const value = item ? (item[f] || '') : '';
          const placeholder = f === 'placa' ? 'Ex: ABC-1234' : f === 'imei' ? 'Ex: 865190072028015' : `Digite o ${f}`;
          html += `<div class="${config.fields.length > 3 ? 'md:col-span-1' : 'md:col-span-2'}">
            <label class="block text-sm font-medium text-slate-300 mb-1.5 capitalize">${f}${isRequired ? ' *' : ''}</label>
            <input name="${f}" value="${value}" placeholder="${placeholder}" 
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2.5 text-white placeholder-slate-500 focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition-all"
              ${isRequired ? 'required' : ''} />
            <p class="error-msg">Este campo é obrigatório</p>
          </div>`;
        });

        fieldsContainer.innerHTML = html;
        
        const modal = document.getElementById('modal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        
        setTimeout(() => {
          const firstInput = modal.querySelector('input:not([type="hidden"])');
          if (firstInput) firstInput.focus();
        }, 100);

        const form = document.getElementById('modal-form');
        const newForm = form.cloneNode(true);
        form.parentNode.replaceChild(newForm, form);
        
        newForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          let isValid = true;
          newForm.querySelectorAll('[required]').forEach(input => {
            if (!input.value.trim()) {
              input.classList.add('input-error');
              isValid = false;
            } else {
              input.classList.remove('input-error');
            }
          });

          if (!isValid) {
            showToast('Preencha todos os campos obrigatórios', 'error');
            return;
          }

          const data = Object.fromEntries(new FormData(newForm));
          const isEdit = !!data._id;
          const submitBtn = document.getElementById('modal-submit');
          const submitText = document.getElementById('modal-submit-text');
          
          submitBtn.classList.add('btn-loading');
          submitText.textContent = isEdit ? 'Salvando...' : 'Adicionando...';
          
          try {
            await fetch(`/api/${config.apiName}`, {
              method: isEdit ? 'PUT' : 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify(data)
            });
            closeModal();
            renderTable(type);
            showToast(isEdit ? 'Registro atualizado com sucesso' : 'Registro criado com sucesso');
          } catch (err) {
            showToast('Erro ao salvar. Tente novamente.', 'error');
          } finally {
            submitBtn.classList.remove('btn-loading');
            submitText.textContent = isEdit ? 'Salvar Alterações' : 'Salvar';
          }
        });
      }

      // --- DASHBOARD & MAP ---
      async function updateDashboard() {
        try {
          let veiculos = await fetch('/api/veiculo').then(r => r.json());
          veiculos = veiculos.error ? [] : veiculos;
          if (empresaAtiva) {
            const empId = empresaAtiva._id.$oid || empresaAtiva._id;
            veiculos = veiculos.filter(v => v.empresaId === empId);
          }
          const now = new Date();
          const counts = {'0-1':0, '1-6':0, '6-24':0, '24-48':0, '48+':0};
          veiculos.forEach(v => {
            const date = v.ultimaPosicao ? new Date(v.ultimaPosicao) : new Date(v.dataCriacao);
            const hours = (now - date) / 36e5;
            if (hours <= 1) counts['0-1']++;
            else if (hours <= 6) counts['1-6']++;
            else if (hours <= 24) counts['6-24']++;
            else if (hours <= 48) counts['24-48']++;
            else counts['48+']++;
          });
          const total = veiculos.length || 1;
          Object.keys(counts).forEach(k => {
            document.getElementById(`count-${k}`).textContent = counts[k];
            document.getElementById(`percent-${k}`).textContent = ((counts[k]/total)*100).toFixed(1) + '%';
            const circle = document.getElementById(`circle-${k}`);
            if(circle) circle.setAttribute('stroke-dashoffset', 251.2 - (251.2 * counts[k]/total));
          });
        } catch(e) { console.error(e); }
      }

      function initMap() {
        if (map) { map.invalidateSize(); return; }
        map = L.map('map').setView([-14.235, -51.9253], 4);
        osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        satelliteLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png');
        document.getElementById('map-type').addEventListener('change', (e) => {
          if (e.target.value === 'satellite') { map.removeLayer(osmLayer); satelliteLayer.addTo(map); }
          else { map.removeLayer(satelliteLayer); osmLayer.addTo(map); }
        });
        addMarkers();
      }

      function initRadarMap() {
        if (radarMap) { radarMap.invalidateSize(); return; }
        radarMap = L.map('radar-map').setView([-22.9068, -43.1729], 13);
        osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(radarMap);
      }

      async function addMarkers() {
        if (!map) return;
        markers.forEach(m => map.removeLayer(m));
        markers = [];
        let veiculos = await fetch('/api/veiculo').then(r => r.json());
        veiculos = veiculos.error ? [] : veiculos;
        if (empresaAtiva) {
          const empId = empresaAtiva._id.$oid || empresaAtiva._id;
          veiculos = veiculos.filter(v => v.empresaId === empId);
        }
        veiculos.forEach(v => {
          if (v.latitude && v.longitude) {
            markers.push(L.marker([v.latitude, v.longitude]).addTo(map).bindPopup(`<b>${v.placa}</b><br>${v.marca || ''}`));
          }
        });
      }
    </script>