---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FleetTrack - Sistema de Rastreamento</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <style>
      /* Sidebar Styles */
      .sidebar-container { transition: width 0.3s ease; }
      .sidebar-container.collapsed { width: 5rem; } 
      .sidebar-container.collapsed .menu-text { display: none; }
      
      /* Scrollbars */
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: #0f172a; }
      ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #475569; }
      
      /* Company Dropdown */
      .company-selector-btn {
        display: flex; align-items: center; justify-content: space-between;
        width: 100%; padding: 0.75rem 1rem; background: #1e293b;
        border-radius: 0.5rem; cursor: pointer; transition: all 0.2s;
        border: 1px solid #334155;
      }
      .company-selector-btn:hover { background: #334155; border-color: #475569; }
      .company-selector-btn.active { background: #1e293b; border-color: #ef4444; }
      
      .company-dropdown-content {
        position: absolute; top: calc(100% + 0.5rem); left: 0; right: 0;
        background: #1e293b; border: 1px solid #334155; border-radius: 0.5rem;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.6); z-index: 60;
        overflow: hidden; opacity: 0; transform: translateY(-10px);
        transition: all 0.2s ease-out; pointer-events: none;
      }
      .company-dropdown-content.open { opacity: 1; transform: translateY(0); pointer-events: auto; }
      
      .company-item {
        display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem;
        cursor: pointer; transition: background 0.15s;
      }
      .company-item:hover { background: #0f172a; }
      .company-item.active { background: #dc2626; color: white; }
      .company-item.active .text-slate-400 { color: #fee2e2; }
      
      /* Mapas */
      #map, #radar-map { height: 500px; z-index: 1; border-radius: 0.5rem; }
      #radar-map { height: 600px; }

      /* Animações */
      @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
      @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
      .toast-enter { animation: slideIn 0.3s ease-out forwards; }
      .modal-enter { animation: fadeIn 0.2s ease-out forwards; }
      .dropdown-enter { animation: fadeIn 0.15s ease-out forwards; }
      
      /* Inputs & Erros */
      .input-error { border-color: #ef4444 !important; }
      .error-msg { color: #ef4444; font-size: 0.75rem; margin-top: 0.25rem; display: none; }
      .input-error + .error-msg { display: block; }
      
      /* Loading Buttons */
      .btn-loading { position: relative; color: transparent !important; }
      .btn-loading::after {
        content: ""; position: absolute; width: 16px; height: 16px;
        top: 50%; left: 50%; margin-top: -8px; margin-left: -8px;
        border: 2px solid rgba(255,255,255,0.3); border-top-color: white;
        border-radius: 50%; animation: spin 0.6s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* Header Dropdowns */
      .header-dropdown {
        position: absolute; top: calc(100% + 0.5rem); right: 0;
        background: #1e293b; border: 1px solid #334155; border-radius: 0.75rem;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5); z-index: 70;
        min-width: 280px; overflow: hidden; opacity: 0; transform: translateY(-8px);
        transition: all 0.2s ease-out; pointer-events: none;
      }
      .header-dropdown.open { opacity: 1; transform: translateY(0); pointer-events: auto; }
      .header-dropdown.wide { min-width: 360px; }
      
      .dropdown-item {
        display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem;
        cursor: pointer; transition: background 0.15s;
      }
      .dropdown-item:hover { background: #334155; }
      .dropdown-item.danger:hover { background: #7f1d1d; }
      
      .notification-badge {
        position: absolute; top: -2px; right: -2px;
        width: 18px; height: 18px; background: #ef4444;
        border-radius: 50%; font-size: 0.65rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid #0f172a;
      }

      /* Light Mode Overrides */
      html:not(.dark) body { background: #f1f5f9; color: #1e293b; }
      html:not(.dark) .bg-slate-950 { background: #f8fafc; }
      html:not(.dark) .bg-slate-900 { background: #ffffff; }
      html:not(.dark) .bg-slate-800 { background: #f1f5f9; }
      html:not(.dark) .bg-slate-800\/50 { background: #f1f5f9; }
      html:not(.dark) .bg-slate-800\/30 { background: #f8fafc; }
      html:not(.dark) .border-slate-800 { border-color: #e2e8f0; }
      html:not(.dark) .border-slate-700 { border-color: #cbd5e1; }
      html:not(.dark) .border-slate-600 { border-color: #94a3b8; }
      html:not(.dark) .text-slate-100 { color: #0f172a; }
      html:not(.dark) .text-slate-300 { color: #334155; }
      html:not(.dark) .text-slate-400 { color: #64748b; }
      html:not(.dark) .text-slate-500 { color: #94a3b8; }
      html:not(.dark) .text-white { color: #0f172a; }
      html:not(.dark) input, html:not(.dark) select { background: #ffffff; border-color: #cbd5e1; color: #0f172a; }
      html:not(.dark) ::-webkit-scrollbar-track { background: #f1f5f9; }
      html:not(.dark) ::-webkit-scrollbar-thumb { background: #cbd5e1; }
      html:not(.dark) .company-selector-btn { background: #ffffff; border-color: #e2e8f0; }
      html:not(.dark) .company-selector-btn:hover { background: #f1f5f9; }
      html:not(.dark) .company-dropdown-content { background: #ffffff; border-color: #e2e8f0; }
      html:not(.dark) .company-item:hover { background: #f1f5f9; }
      html:not(.dark) .header-dropdown { background: #ffffff; border-color: #e2e8f0; }
      html:not(.dark) .dropdown-item:hover { background: #f1f5f9; }
      html:not(.dark) .dropdown-item.danger:hover { background: #fef2f2; }
      html:not(.dark) #map, html:not(.dark) #radar-map { background: #e2e8f0; }
      html:not(.dark) .toast-enter { background: #10b981 !important; }
      html:not(.dark) .notification-badge { border-color: #f8fafc; }

      /* Radar Styles */
      .radar-card {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border: 1px solid #334155;
      }
      .radar-stat-value { font-size: 2rem; font-weight: 700; }
      .radar-result-item { transition: all 0.2s; }
      .radar-result-item:hover { background: #1e293b; transform: translateX(4px); }
      .search-circle { fill: rgba(59, 130, 246, 0.1); stroke: #3b82f6; stroke-width: 2; stroke-dasharray: 5,5; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased transition-colors duration-300">
    <!-- Toast Container -->
    <div id="toast-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"></div>

    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar Dupla -->
      <aside class="sidebar-container w-72 bg-slate-900 border-r border-slate-800 flex flex-row fixed h-full z-50">
        <!-- Coluna Ícones (Rail) -->
        <div class="w-16 flex flex-col items-center py-6 border-r border-slate-800 bg-slate-900 shrink-0">
          <button id="sidebar-toggle" class="w-full flex justify-center p-2 mb-6 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors" title="Recolher Menu">
            <svg class="rail-icon w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
            </svg>
          </button>
          <nav class="flex-1 space-y-2 w-full px-2">
            <button onclick="changePage('inicio')" class="rail-btn w-full flex justify-center p-2.5 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="inicio" title="Início">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
            </button>
            <button onclick="changePage('radar')" class="rail-btn w-full flex justify-center p-2.5 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="radar" title="Radar de Vendas">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </button>
            <button onclick="changePage('empresa')" class="rail-btn w-full flex justify-center p-2.5 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="empresa" title="Empresas">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            </button>
            <button onclick="changePage('equipamento')" class="rail-btn w-full flex justify-center p-2.5 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="equipamento" title="Equipamentos">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
            </button>
            <button onclick="changePage('veiculo')" class="rail-btn w-full flex justify-center p-2.5 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="veiculo" title="Veículos">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
            </button>
          </nav>
          <button class="w-full flex justify-center p-2.5 rounded-lg text-slate-500 hover:text-slate-300 hover:bg-slate-800 transition-colors mt-auto" title="Configurações">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </button>
        </div>

        <!-- Coluna Texto -->
        <div class="menu-text flex-1 flex flex-col h-full bg-slate-900 overflow-y-auto">
          <div class="px-4 py-4 border-b border-slate-800 relative">
            <button id="company-selector-btn" class="company-selector-btn">
              <div class="flex items-center gap-3 overflow-hidden">
                <div class="w-8 h-8 rounded bg-red-600 flex items-center justify-center shrink-0"><span class="text-xs font-bold text-white">T</span></div>
                <span class="text-sm font-medium text-white truncate">Empresas...</span>
              </div>
              <svg id="company-arrow" class="w-4 h-4 text-slate-400 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="company-dropdown" class="company-dropdown-content">
              <div class="p-2 border-b border-slate-700 bg-slate-800">
                <div class="relative">
                  <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                  <input type="text" id="company-search" placeholder="Pesquisar empresa..." class="w-full pl-9 pr-3 py-1.5 bg-slate-900 border border-slate-600 rounded text-sm text-white placeholder-slate-500 focus:outline-none focus:border-red-500">
                </div>
              </div>
              <div id="company-list" class="overflow-y-auto max-h-60 py-1 bg-slate-800"></div>
            </div>
          </div>

          <nav class="flex-1 px-4 py-4 space-y-1">
            <a href="#" class="nav-item active flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium bg-red-600/10 text-red-500 transition-all" data-tab="inicio">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
              <span>Início</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="radar">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span>Radar de Vendas</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="empresa">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              <span>Empresas</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="equipamento">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
              <span>Equipamentos</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="veiculo">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
              <span>Veículos</span>
            </a>
          </nav>

          <div class="p-4 border-t border-slate-800">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-xs font-bold text-white shrink-0">F</div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate">Admin</p>
                <p class="text-xs text-slate-500 truncate">admin@fleettrack.com</p>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 ml-72 flex flex-col min-w-0 bg-slate-950 transition-all duration-300" id="main-content">
        <!-- Header -->
        <header class="h-16 bg-slate-900 border-b border-slate-800 flex items-center justify-end px-6 sticky top-0 z-40">
          <div class="flex items-center gap-2">
            <!-- Theme Toggle -->
            <div class="relative">
              <button id="theme-toggle" class="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors" title="Alternar Tema">
                <svg id="moon-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
                <svg id="sun-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
              </button>
            </div>

            <!-- Notifications -->
            <div class="relative">
              <button id="notif-btn" class="relative p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                <span id="notif-badge" class="notification-badge">4</span>
              </button>
              <div id="notif-dropdown" class="header-dropdown wide dropdown-enter hidden">
                <div class="p-3 border-b border-slate-700 flex items-center justify-between">
                  <span class="text-sm font-semibold text-white">Notificações</span>
                  <button id="mark-all-read" class="text-xs text-red-400 hover:text-red-300 transition-colors">Marcar todas como lidas</button>
                </div>
                <div id="notif-list" class="max-h-72 overflow-y-auto"></div>
                <div class="p-2 border-t border-slate-700 text-center">
                  <button class="text-xs text-slate-400 hover:text-white transition-colors">Ver todas as notificações</button>
                </div>
              </div>
            </div>

            <!-- Profile -->
            <div class="relative">
              <button id="profile-btn" class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center text-sm font-medium text-white cursor-pointer hover:bg-red-700 transition-colors ring-2 ring-transparent hover:ring-red-500/50">F</button>
              <div id="profile-dropdown" class="header-dropdown dropdown-enter hidden">
                <div class="p-4 border-b border-slate-700">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-red-600 flex items-center justify-center text-sm font-bold text-white">F</div>
                    <div>
                      <p class="text-sm font-semibold text-white">Fabio Dias</p>
                      <p class="text-xs text-slate-400">admin@fleettrack.com</p>
                    </div>
                  </div>
                </div>
                <div class="py-1">
                  <button class="dropdown-item w-full text-left">
                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    <span class="text-sm text-slate-300">Meu Perfil</span>
