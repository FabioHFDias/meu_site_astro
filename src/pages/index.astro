---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FleetTrack - Sistema de Rastreamento</title>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <style>
      .sidebar-container { transition: width 0.3s ease; }
      .sidebar-container.collapsed { width: 4rem; }
      .sidebar-container.collapsed .menu-text { display: none; }
      .sidebar-container:not(.collapsed) .menu-text { display: block; }
      .sidebar-container .rail-icon { transition: transform 0.3s ease; }
      .sidebar-container.collapsed .rail-icon { transform: rotate(180deg); }
      
      /* Dropdown custom scrollbar */
      #empresa-list::-webkit-scrollbar { width: 6px; }
      #empresa-list::-webkit-scrollbar-track { background: #1e293b; }
      #empresa-list::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }
      #empresa-list::-webkit-scrollbar-thumb:hover { background: #64748b; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <div class="flex h-screen overflow-hidden">
      
      <!-- Sidebar Dupla (Estilo Walkline) -->
      <aside class="sidebar-container w-72 bg-slate-900 border-r border-slate-800 flex flex-row fixed h-full z-50 overflow-hidden">
        
        <!-- Coluna Esquerda: Ícones (Rail) -->
        <div class="w-16 flex flex-col items-center py-6 border-r border-slate-800 bg-slate-900 shrink-0">
          <button id="sidebar-toggle" class="w-full flex justify-center p-2 mb-6 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors" title="Recolher Menu">
            <svg class="rail-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
            </svg>
          </button>

          <nav class="flex-1 space-y-6 w-full px-3">
            <button onclick="changePage('inicio')" class="rail-btn w-full flex justify-center p-2 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="inicio" title="Início">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
            </button>
            <button onclick="changePage('empresas')" class="rail-btn w-full flex justify-center p-2 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="empresas" title="Empresas">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            </button>
            <button onclick="changePage('equipamentos')" class="rail-btn w-full flex justify-center p-2 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="equipamentos" title="Equipamentos">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
            </button>
            <button onclick="changePage('veiculos')" class="rail-btn w-full flex justify-center p-2 rounded-lg hover:bg-slate-800 text-slate-500 hover:text-red-500 transition-colors" data-target="veiculos" title="Veículos">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
            </button>
            <button class="w-full flex justify-center p-2 rounded-lg text-slate-500 hover:text-slate-300 hover:bg-slate-800 transition-colors mt-auto" title="Configurações">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </button>
          </nav>
        </div>

        <!-- Coluna Direita: Menu de Texto -->
        <div class="menu-text flex-1 flex flex-col h-full bg-slate-900 overflow-y-auto custom-scrollbar">
          
          <!-- Header do Menu com Dropdown de Empresas -->
          <div class="px-6 py-6 border-b border-slate-800 relative">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Menu Principal</span>
            </div>
            
            <!-- Dropdown Trigger -->
            <div class="relative">
              <button id="empresa-dropdown-btn" class="flex items-center gap-2 text-white font-semibold cursor-pointer hover:text-slate-200 transition-colors w-full text-left py-1">
                <span id="empresa-dropdown-label">Empresas</span>
                <svg id="empresa-dropdown-arrow" class="w-4 h-4 text-slate-500 ml-auto transition-transform duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              
              <!-- Dropdown Menu -->
              <div id="empresa-dropdown" class="absolute top-full left-0 right-0 mt-2 bg-slate-800 border border-slate-700 rounded-lg shadow-2xl overflow-hidden hidden z-50">
                <div class="p-2 border-b border-slate-700">
                  <div class="relative">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    <input type="text" id="empresa-search" placeholder="Pesquisar empresa..." class="w-full pl-9 pr-3 py-2 bg-slate-900 border border-slate-600 rounded-md text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent">
                  </div>
                </div>
                <div id="empresa-list" class="max-h-64 overflow-y-auto py-1">
                  <!-- Lista injetada via JS -->
                </div>
              </div>
            </div>
          </div>

          <!-- Lista de Navegação -->
          <nav class="flex-1 px-4 py-4 space-y-1">
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all" data-tab="inicio">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
              <span>Início</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all" data-tab="empresas">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              <span>Empresas</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all" data-tab="equipamentos">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
              <span>Equipamentos</span>
            </a>
            <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all" data-tab="veiculos">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
              <span>Veículos</span>
            </a>
          </nav>

          <!-- Footer do Menu -->
          <div class="p-4 border-t border-slate-800">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-xs font-bold text-white shrink-0">F</div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate">Admin</p>
                <p class="text-xs text-slate-500 truncate">admin@fleettrack.com</p>
              </div>
              <button class="text-slate-400 hover:text-white shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg></button>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 ml-72 flex flex-col min-w-0 bg-slate-950 transition-all duration-300" id="main-content">
        <header class="h-16 bg-slate-900 border-b border-slate-800 flex items-center justify-between px-6 sticky top-0 z-40">
          <div class="flex items-center gap-4"></div>
          <div class="flex items-center gap-4">
            <button class="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
            </button>
            <button class="relative p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
              <span class="absolute top-1.5 right-1.5 w-4 h-4 bg-red-500 rounded-full text-xs flex items-center justify-center text-white font-medium">4</span>
            </button>
            <div class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center text-sm font-medium text-white cursor-pointer hover:bg-red-700 transition-colors">F</div>
          </div>
        </header>

        <div class="flex-1 overflow-auto p-6">
          <div class="max-w-[1600px] mx-auto space-y-6">
            <div class="mb-4">
              <h1 class="text-xl font-semibold text-white mb-1" id="page-title">Dashboard</h1>
              <p class="text-sm text-slate-400" id="page-subtitle">Visualize e acompanhe sua frota em tempo real através do mapa interativo.</p>
            </div>

            <div id="dashboard-content">
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 mb-6">
                <div class="flex items-center justify-between mb-6">
                  <div>
                    <h2 class="text-lg font-semibold text-white">Status de Transmissão</h2>
                    <p class="text-sm text-slate-400 mt-1">Distribuição dos veículos conforme o tempo desde seu último sinal.</p>
                  </div>
                  <button class="flex items-center gap-2 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
                    Filtrar por Empresa
                  </button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">0h à 1h</h3><p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4"><svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120"><circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" /><circle cx="60" cy="60" r="54" fill="none" stroke="#22c55e" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="243.5" /></svg><div class="absolute inset-0 flex flex-col items-center justify-center"><span class="text-2xl font-bold text-white">447</span><span class="text-xs text-slate-400">Veículos</span></div></div>
                    <p class="text-sm font-semibold text-emerald-400">28.11%</p><p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">1h à 6h</h3><p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4"><svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120"><circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" /><circle cx="60" cy="60" r="54" fill="none" stroke="#84cc16" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="305.4" /></svg><div class="absolute inset-0 flex flex-col items-center justify-center"><span class="text-2xl font-bold text-white">159</span><span class="text-xs text-slate-400">Veículos</span></div></div>
                    <p class="text-sm font-semibold text-lime-400">10.00%</p><p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">6h à 24h</h3><p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4"><svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120"><circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" /><circle cx="60" cy="60" r="54" fill="none" stroke="#f59e0b" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="307.2" /></svg><div class="absolute inset-0 flex flex-col items-center justify-center"><span class="text-2xl font-bold text-white">150</span><span class="text-xs text-slate-400">Veículos</span></div></div>
                    <p class="text-sm font-semibold text-amber-400">9.43%</p><p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">24h à 48h</h3><p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4"><svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120"><circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" /><circle cx="60" cy="60" r="54" fill="none" stroke="#f97316" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="331.1" /></svg><div class="absolute inset-0 flex flex-col items-center justify-center"><span class="text-2xl font-bold text-white">39</span><span class="text-xs text-slate-400">Veículos</span></div></div>
                    <p class="text-sm font-semibold text-orange-400">2.45%</p><p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">48h +</h3><p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4"><svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120"><circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" /><circle cx="60" cy="60" r="54" fill="none" stroke="#ef4444" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="183.6" /></svg><div class="absolute inset-0 flex flex-col items-center justify-center"><span class="text-2xl font-bold text-white">731</span><span class="text-xs text-slate-400">Veículos</span></div></div>
                    <p class="text-sm font-semibold text-red-400">45.97%</p><p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>
                </div>
              </div>
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
                <div class="flex items-center justify-between mb-4">
                  <div><h2 class="text-lg font-semibold text-white">Mapa de Monitoramento</h2><p class="text-sm text-slate-400 mt-1">Visualize e acompanhe sua frota em tempo real através do mapa interativo.</p></div>
                  <div class="flex items-center gap-3"><label class="text-sm text-slate-400">Mapa:</label><select id="map-type" class="px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-red-600"><option value="osm">OpenStreetMap</option><option value="satellite">Satélite (Dark)</option></select></div>
                </div>
                <div id="map" class="relative w-full h-[500px] bg-slate-800 rounded-lg overflow-hidden z-0 border border-slate-700"></div>
              </div>
            </div>

            <div id="list-content" class="hidden space-y-4">
              <div id="tabs-container" class="flex items-center gap-1 border-b border-slate-800 mb-4"></div>
              <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-4 mb-4">
                <div class="flex items-center gap-3 w-full lg:w-auto">
                  <div class="relative flex-1 lg:flex-initial">
                    <input type="text" id="search-input" placeholder="Filtrar..." class="w-full lg:w-64 pl-4 pr-10 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent" />
                    <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                  </div>
                  <button class="flex items-center gap-2 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
                    Aplicar Filtros
                  </button>
                </div>
                <div class="flex items-center gap-3 w-full lg:w-auto">
                  <button class="hidden flex items-center gap-2 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors" id="btn-mass-commands">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    Comandos em Massa
                  </button>
                  <button id="btn-add" class="flex items-center gap-2 px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 transition-colors shadow-lg shadow-red-900/50">
