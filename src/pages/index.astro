---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FleetTrack - Sistema de Rastreamento</title>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <div class="flex h-screen overflow-hidden">
      
      <!-- Sidebar -->
      <aside class="w-64 bg-slate-900 border-r border-slate-800 flex flex-col fixed h-full z-50">
        <!-- Logo -->
        <div class="h-16 flex items-center gap-3 px-6 border-b border-slate-800">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <span class="text-lg font-bold text-white">F</span>
          </div>
          <div>
            <h1 class="font-bold text-white text-sm">FleetTrack</h1>
            <p class="text-xs text-slate-400">Sistema de Rastreamento</p>
          </div>
        </div>

        <!-- Menu -->
        <nav class="flex-1 py-6 px-3 space-y-1">
          <a href="#" class="nav-item active flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium bg-blue-600 text-white transition-all" data-tab="inicio">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Início
          </a>
          
          <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="empresas">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            Empresas
          </a>
          
          <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="equipamentos">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
            Equipamentos
          </a>
          
          <a href="#" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-all" data-tab="veiculos">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Veículos
          </a>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 ml-64 flex flex-col min-w-0 bg-slate-950">
        <!-- Top Header -->
        <header class="h-16 bg-slate-900 border-b border-slate-800 flex items-center justify-between px-6 sticky top-0 z-40">
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2 px-3 py-1.5 bg-slate-800 rounded-lg cursor-pointer hover:bg-slate-700 transition-colors">
              <span class="text-sm font-medium text-white">Empresas...</span>
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <button class="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>
            
            <button class="relative p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              <span class="absolute top-1.5 right-1.5 w-4 h-4 bg-red-500 rounded-full text-xs flex items-center justify-center text-white font-medium">4</span>
            </button>

            <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-sm font-medium text-white cursor-pointer hover:bg-blue-700 transition-colors">
              F
            </div>
          </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-auto p-6">
          <div class="max-w-[1600px] mx-auto space-y-6">
            
            <!-- Page Header -->
            <div class="mb-4">
              <h1 class="text-xl font-semibold text-white mb-1" id="page-title">Dashboard</h1>
              <p class="text-sm text-slate-400" id="page-subtitle">Visualize e acompanhe sua frota em tempo real através do mapa interativo.</p>
            </div>

            <!-- DASHBOARD CONTENT -->
            <div id="dashboard-content">
              <!-- Status de Transmissão -->
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 mb-6">
                <div class="flex items-center justify-between mb-6">
                  <div>
                    <h2 class="text-lg font-semibold text-white">Status de Transmissão</h2>
                    <p class="text-sm text-slate-400 mt-1">Distribuição dos veículos conforme o tempo desde seu último sinal.</p>
                  </div>
                  <button class="flex items-center gap-2 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                    </svg>
                    Filtrar por Empresa
                  </button>
                </div>

                <!-- Cards de Status -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                  
                  <!-- 0h à 1h -->
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">0h à 1h</h3>
                    <p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4">
                      <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" />
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#22c55e" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="243.5" />
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-bold text-white">447</span>
                        <span class="text-xs text-slate-400">Veículos</span>
                      </div>
                    </div>
                    <p class="text-sm font-semibold text-emerald-400">28.11%</p>
                    <p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>

                  <!-- 1h à 6h -->
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">1h à 6h</h3>
                    <p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4">
                      <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" />
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#84cc16" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="305.4" />
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-bold text-white">159</span>
                        <span class="text-xs text-slate-400">Veículos</span>
                      </div>
                    </div>
                    <p class="text-sm font-semibold text-lime-400">10.00%</p>
                    <p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>

                  <!-- 6h à 24h -->
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">6h à 24h</h3>
                    <p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4">
                      <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" />
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#f59e0b" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="307.2" />
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-bold text-white">150</span>
                        <span class="text-xs text-slate-400">Veículos</span>
                      </div>
                    </div>
                    <p class="text-sm font-semibold text-amber-400">9.43%</p>
                    <p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>

                  <!-- 24h à 48h -->
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">24h à 48h</h3>
                    <p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4">
                      <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" />
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#f97316" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="331.1" />
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-bold text-white">39</span>
                        <span class="text-xs text-slate-400">Veículos</span>
                      </div>
                    </div>
                    <p class="text-sm font-semibold text-orange-400">2.45%</p>
                    <p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>

                  <!-- 48h+ -->
                  <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 text-center">
                    <h3 class="text-sm font-semibold text-white mb-1">48h +</h3>
                    <p class="text-xs text-slate-400 mb-4">Maio de 2026</p>
                    <div class="relative w-32 h-32 mx-auto mb-4">
                      <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#1e293b" stroke-width="8" />
                        <circle cx="60" cy="60" r="54" fill="none" stroke="#ef4444" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="183.6" />
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-bold text-white">731</span>
                        <span class="text-xs text-slate-400">Veículos</span>
                      </div>
                    </div>
                    <p class="text-sm font-semibold text-red-400">45.97%</p>
                    <p class="text-xs text-slate-400 mt-1">do total de veículos</p>
                  </div>

                </div>
              </div>

              <!-- Mapa de Monitoramento -->
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
                <div class="flex items-center justify-between mb-4">
                  <div>
                    <h2 class="text-lg font-semibold text-white">Mapa de Monitoramento</h2>
                    <p class="text-sm text-slate-400 mt-1">Visualize e acompanhe sua frota em tempo real através do mapa interativo.</p>
                  </div>
                  <div class="flex items-center gap-3">
                    <label class="text-sm text-slate-400">Mapa:</label>
                    <select id="map-type" class="px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-600">
                      <option value="osm">OpenStreetMap</option>
                      <option value="satellite">Satélite (Dark)</option>
                    </select>
                  </div>
                </div>

                <!-- Mapa Leaflet -->
                <div id="map" class="relative w-full h-[500px] bg-slate-800 rounded-lg overflow-hidden z-0 border border-slate-700"></div>
              </div>
            </div>

            <!-- LIST CONTENT (Empresas, Equipamentos, Veículos) -->
            <div id="list-content" class="hidden space-y-4">
              <!-- Tabs Container -->
              <div id="tabs-container" class="flex items-center gap-1 border-b border-slate-800 mb-4"></div>

              <!-- Toolbar -->
              <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-4 mb-4">
                <div class="flex items-center gap-3 w-full lg:w-auto">
                  <div class="relative flex-1 lg:flex-initial">
                    <input 
                      type="text" 
                      id="search-input"
                      placeholder="Filtrar..." 
                      class="w-full lg:w-64 pl-4 pr-10 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent"
                    />
                    <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                  </div>
                  <button class="flex items-center gap-2 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                    </svg>
                    Aplicar Filtros
                  </button>
                </div>
                
                <div class="flex items-center gap-3 w-full lg:w-auto">
                  <button class="hidden flex items-center gap-2 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors" id="btn-mass-commands">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Comandos em Massa
                  </button>
                  <button 
                    id="btn-add"
                    class="flex items-center gap-2 px-4 py-2 bg-white text-slate-900 rounded-lg text-sm font-medium hover:bg-slate-100 transition-colors shadow-lg"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span id="btn-add-text">Adicionar</span>
                  </button>
                </div>
              </div>

              <!-- Table -->
              <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead class="bg-slate-800/50 border-b border-slate-800">
                      <tr id="table-header"></tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800" id="table-body"></tbody>
                  </table>
                </div>
                
                <!-- Pagination -->
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 px-4 py-3 border-t border-slate-800 bg-slate-800/30">
                  <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2">
                      <label class="text-xs text-slate-400">Fileiras Por Página</label>
                      <select class="px-2 py-1 bg-slate-800 border border-slate-700 rounded text-xs text-white focus:outline-none focus:ring-2 focus:ring-blue-600">
                        <option>25</option>
                        <option>50</option>
                        <option>100</option>
                      </select>
                    </div>
                    <span class="text-xs text-slate-400">Total de itens: <strong class="text-white" id="total-items">0</strong></span>
                  </div>
                  
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-slate-400">Página <strong class="text-white">1</strong> de <strong class="text-white" id="total-pages">1</strong></span>
                    <div class="flex items-center gap-1">
                      <button class="p-1.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" /></svg></button>
                      <button class="p-1.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg></button>
                      <button class="p-1.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></button>
                      <button class="p-1.5 text-slate-400 hover:text-white hover:bg-slate-800 rounded transition-colors"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" /></svg></button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </main>
    </div>

    <!-- Modal -->
    <div id="modal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4">
      <div class="w-full max-w-2xl bg-slate-900 border border-slate-800 rounded-xl shadow-2xl">
        <div class="flex items-center justify-between p-6 border-b border-slate-800">
          <h3 class="text-lg font-semibold text-white" id="modal-title">Adicionar</h3>
          <button class="close text-slate-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <form id="modal-form" class="p-6 space-y-4">
          <div id="modal-fields" class="grid grid-cols-2 gap-4"></div>
          <div class="flex justify-end gap-3 pt-4 border-t border-slate-800">
            <button type="button" id="modal-cancel" class="px-4 py-2 text-sm font-medium text-slate-300 bg-slate-800 hover:bg-slate-700 rounded-lg transition-colors">Cancelar</button>
            <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors shadow-lg shadow-blue-600/25">Salvar</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      // Dados de exemplo - EMPRESAS
      const empresas = [
        { nomeFantasia: "Altis Tec", razaoSocial: "ALTIS TECNOLOGIA LTDA", gatewayIntegrado: "Não Integrado", empresaMae: "N/A", dataCriacao: "14/10/2025, 18:23", criadoPor: "José Antônio", subdominio: "altistec", status: true, statusFinanceiro: true },
        { nomeFantasia: "Anjo Da Guarda...", razaoSocial: "anjo da guarda rastreamento", gatewayIntegrado: "Não Integrado", empresaMae: "Arqueiros...", dataCriacao: "18/12/2023, 18:19", criadoPor: "Admin master", subdominio: "anjodaguardarastreamento", status: false, statusFinanceiro: false },
        { nomeFantasia: "Arqueiros Rastreament...", razaoSocial: "MARCELA KETHLEEN MOREI...", gatewayIntegrado: "Integrado", empresaMae: "N/A", dataCriacao: "11/09/2023, 12:46", criadoPor: "Admin master", subdominio: "arqueirostelemetria", status: true, statusFinanceiro: true },
        { nomeFantasia: "Aventis Locadora", razaoSocial: "AVENTIS CAR LOCADORA DE...", gatewayIntegrado: "Não Integrado", empresaMae: "N/A", dataCriacao: "22/08/2024, 12:50", criadoPor: "Admin master", subdominio: "aventislocadora", status: true, statusFinanceiro: true },
