        },
        veiculos: {
          title: "Veículos", subtitle: "Lista de Veículos Registrados", tabs: ["Veículos", "Periféricos", "Área de Segurança", "Ranking", "Vincular Equipamentos"], searchPlaceholder: "Filtrar pelo cliente...", btnAddText: "Adicionar Veículo", showMassCommands: false, totalItems: 1636, totalPages: 66,
          columns: [
            { key: "empresa", label: "Nome da Empresa", sortable: true },
            { key: "proprietario", label: "Proprietário", sortable: false },
            { key: "marca", label: "Marca", sortable: false },
