      // --- MAP ---
      function initMap() {
        if (map) { map.invalidateSize(); return; }
        map = L.map('map', { center: [-14.235, -51.9253], zoom: 4, zoomControl: false, attributionControl: false });
        L.control.zoom({ position: 'bottomright' }).addTo(map);
        osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19, attribution: '© OpenStreetMap' });
        satelliteLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { maxZoom: 19, attribution: '© CartoDB' });
        osmLayer.addTo(map);
        document.getElementById('map-type')?.addEventListener('change', (e) => {
          if (e.target.value === 'satellite') { map.removeLayer(osmLayer); satelliteLayer.addTo(map); } 
          else { map.removeLayer(satelliteLayer); osmLayer.addTo(map); }
        });
        addMarkers();
      }
      function addMarkers() {
        markers.forEach(m => map.removeLayer(m)); markers = [];
        veiculosMapa.forEach(v => {
          let color = '#22c55e'; if (v.status === 'offline') color = '#ef4444'; if (v.status === 'warning') color = '#f59e0b';
          const icon = L.divIcon({ className: 'custom-marker', html: `<div style="width:16px;height:16px;background:${color};border:3px solid white;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.4);animation:pulse 2s infinite;"></div>`, iconSize: [16,16], iconAnchor: [8,8] });
          markers.push(L.marker([v.lat, v.lng], { icon }).addTo(map).bindPopup(`<div style="min-width:200px;font-family:system-ui;"><h3 style="margin:0 0 8px;font-size:14px;font-weight:600;color:#1e293b;">${v.placa}</h3><div style="font-size:12px;color:#64748b;"><p style="margin:4px 0;"><strong>Empresa:</strong> ${v.empresa}</p><p style="margin:4px 0;"><strong>Status:</strong> <span style="color:${color};font-weight:600;">${v.status === 'online' ? '● Online' : v.status === 'offline' ? '● Offline' : '● Alerta'}</span></p></div></div>`));
        });
        if (!document.getElementById('map-styles')) {
          const style = document.createElement('style'); style.id = 'map-styles'; style.textContent = `@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.3);opacity:.7}}.leaflet-popup-content-wrapper{background:white;border-radius:8px;box-shadow:0 4px 12px rgba(0,0,0,.15)}.leaflet-popup-tip{background:white}.leaflet-container{font-family:inherit}`;
          document.head.appendChild(style);
        }
      }

      // --- PAGE CONTROL ---
      function changePage(page) {
        currentPage = page; const config = pagesConfig[page];
        document.querySelectorAll('.nav-item').forEach(item => {
          item.classList.remove('active', 'bg-slate-800', 'text-red-500'); item.classList.add('text-slate-400');
          const icon = item.querySelector('svg'), text = item.querySelector('span');
          if (icon) icon.classList.remove('text-red-500'), icon.classList.add('text-slate-500');
          if (text) text.classList.remove('text-red-500'), text.classList.add('text-slate-400');
        });
        document.querySelectorAll('.rail-btn').forEach(btn => { btn.classList.remove('text-red-500', 'bg-slate-800'); btn.classList.add('text-slate-500'); });

        const activeItem = document.querySelector(`.nav-item[data-tab="${page}"]`);
        if (activeItem) {
          activeItem.classList.add('active', 'bg-slate-800', 'text-red-500');
          const icon = activeItem.querySelector('svg'), text = activeItem.querySelector('span');
          if (icon) icon.classList.remove('text-slate-500'), icon.classList.add('text-red-500');
          if (text) text.classList.remove('text-slate-400'), text.classList.add('text-red-500');
        }
        const activeRail = document.querySelector(`.rail-btn[data-target="${page}"]`);
        if (activeRail) activeRail.classList.remove('text-slate-500'), activeRail.classList.add('text-red-500', 'bg-slate-800');

        document.getElementById('page-title').textContent = config.title;
        document.getElementById('page-subtitle').textContent = config.subtitle;
        const dash = document.getElementById('dashboard-content'), list = document.getElementById('list-content');
        if (config.isDashboard) { dash.classList.remove('hidden'); list.classList.add('hidden'); setTimeout(initMap, 100); } 
        else { dash.classList.add('hidden'); list.classList.remove('hidden');
          document.getElementById('search-input').placeholder = config.searchPlaceholder;
          document.getElementById('btn-add-text').textContent = config.btnAddText;
          const btnMass = document.getElementById('btn-mass-commands');
          if (config.showMassCommands) btnMass.classList.remove('hidden'), btnMass.classList.add('flex');
          else btnMass.classList.add('hidden'), btnMass.classList.remove('flex');
          document.getElementById('total-items').textContent = config.totalItems;
          document.getElementById('total-pages').textContent = config.totalPages;
          renderTabs(config.tabs); renderTableHeader(config.columns);
          if (page === 'empresas') renderEmpresasTable();
          else if (page === 'equipamentos') renderEquipamentosTable();
          else renderVeiculosTable();
        }
      }

      // --- MODAL ---
      const modal = document.getElementById('modal'), closeBtn = document.querySelector('.close'), cancelBtn = document.getElementById('modal-cancel'), addBtn = document.getElementById('btn-add');
      function openModal() {
        const config = pagesConfig[currentPage]; if (config.isDashboard) return;
        document.getElementById('modal-title').textContent = `Adicionar ${config.title.slice(0, -1)}`;
        document.getElementById('modal-fields').innerHTML = config.modalFields.map(f => `<div><label class="block text-sm font-medium text-slate-300 mb-1">${f.label}</label><input type="${f.type}" class="w-full px-3 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-red-600" required /></div>`).join('');
        modal.classList.remove('hidden'); modal.classList.add('flex');
      }
      function closeModal() { modal.classList.add('hidden'); modal.classList.remove('flex'); }
      closeBtn?.addEventListener('click', closeModal); cancelBtn?.addEventListener('click', closeModal); addBtn?.addEventListener('click', openModal);
      modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal(); });

      // --- INIT ---
      document.querySelectorAll('.nav-item').forEach(item => item.addEventListener('click', (e) => { e.preventDefault(); changePage(e.currentTarget.dataset.tab); }));
      window.changePage = changePage;
      changePage('inicio');
    </script>
  </body>
</html>