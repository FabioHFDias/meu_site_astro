---
// Não precisa de lógica de servidor aqui, é tudo client-side
---

<div id="radar-view" class="hidden space-y-6">
  <div class="mb-4">
    <h1 class="text-2xl font-bold text-white mb-1">Radar de Vendas</h1>
    <p class="text-sm text-slate-400">Busca inteligente por segmento de mercado</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="radar-card rounded-xl p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400 mb-1">Total Encontrados</p>
          <p class="radar-stat-value text-white" id="radar-total">0</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-blue-500/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
      </div>
    </div>
    <div class="radar-card rounded-xl p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400 mb-1">Contatados</p>
          <p class="radar-stat-value text-amber-400" id="radar-contatados">0</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-amber-500/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </div>
      </div>
    </div>
    <div class="radar-card rounded-xl p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400 mb-1">Convertidos</p>
          <p class="radar-stat-value text-emerald-400" id="radar-convertidos">0</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-emerald-500/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Search Controls -->
  <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-300 mb-1.5">Raio de Busca (km)</label>
        <div class="flex items-center gap-2">
          <input type="number" id="search-radius" value="2" min="1" max="50" class="flex-1 px-3 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-slate-400 text-sm">km</span>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-300 mb-1.5">Categoria</label>
        <select id="search-category" class="w-full px-3 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Todas (Categorias Selecionadas)</option>
          <option value="restaurant">Restaurantes</option>
          <option value="market">Mercados</option>
          <option value="service">Serviços</option>
          <option value="retail">Varejo</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-300 mb-1.5">Busca por Nome</label>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <input type="text" id="search-name" placeholder="Filtrar..." class="w-full pl-9 pr-3 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
      </div>
      <div class="flex items-end gap-2">
        <button id="btn-my-location" class="flex-1 px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          Minha Localização
        </button>
        <button id="btn-search-prospects" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors shadow-lg shadow-blue-900/50 flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Buscar Prospects
        </button>
        <button id="btn-export-results" class="px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors" title="Exportar">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Map and Results -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
        <div id="radar-map" class="rounded-lg overflow-hidden border border-slate-700" style="height: 600px;"></div>
      </div>
    </div>
    <div>
      <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
        <div class="p-4 border-b border-slate-800 flex items-center justify-between">
          <h3 class="font-semibold text-white flex items-center gap-2">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
            Resultados (<span id="results-count">0</span>)
          </h3>
        </div>
        <div id="radar-results-list" class="max-h-[550px] overflow-y-auto">
          <div class="p-8 text-center text-slate-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <p class="text-sm">Clique em "Buscar Prospects" para encontrar empresas na região</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .radar-card {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border: 1px solid #334155;
  }
  .radar-stat-value {
    font-size: 2rem;
    font-weight: 700;
  }
  .radar-result-item {
    transition: all 0.2s;
  }
  .radar-result-item:hover {
    background: #1e293b;
    transform: translateX(4px);
  }
  .search-circle {
    fill: rgba(59, 130, 246, 0.1);
    stroke: #3b82f6;
    stroke-width: 2;
    stroke-dasharray: 5,5;
  }
</style>

<script>
  // Lógica JS do Radar isolada neste componente
  let radarMap = null;
  let radarMarkers = [];
  let radarResults = [];
  let userLocation = null;

  export function initRadarMap() {
    if (radarMap) { 
      radarMap.invalidateSize(); 
      return; 
    }
    
    // Inicializa o mapa Leaflet
    radarMap = L.map('radar-map').setView([-22.9068, -43.1729], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(radarMap);
  }

  // Funções expostas para uso externo se necessário
  window.searchProspects = async function() {
    const radius = document.getElementById('search-radius').value || 2;
    const category = document.getElementById('search-category').value;
    const nameFilter = document.getElementById('search-name').value;
    
    const btn = document.getElementById('btn-search-prospects');
    btn.classList.add('btn-loading');
    
    try {
      // Simulação de busca real no banco
      // Aqui você faria o fetch('/api/empresas') real
      const mockEmpresas = [
        { _id: '1', nomeFantasia: 'Padaria do João', razaoSocial: 'Padaria e Confeitaria Ltda', subdominio: 'Centro' },
        { _id: '2', nomeFantasia: 'Mercado Silva', razaoSocial: 'Silva Comércio de Alimentos', subdominio: 'Jardim Paulista' }
      ];
      
      // Filtra por nome
      let empresas = mockEmpresas;
      if (nameFilter) {
        empresas = empresas.filter(e => e.nomeFantasia.toLowerCase().includes(nameFilter.toLowerCase()));
      }

      radarResults = empresas;
      renderRadarResults(empresas, radius);
      showToast(`Encontradas ${empresas.length} empresas no raio de ${radius}km`);
    } catch (err) {
      showToast('Erro ao buscar prospects', 'error');
    } finally {
      btn.classList.remove('btn-loading');
    }
  }

  function renderRadarResults(empresas, radius) {
    const list = document.getElementById('radar-results-list');
    const count = document.getElementById('results-count');
    const total = document.getElementById('radar-total');
    
    count.textContent = empresas.length;
    total.textContent = empresas.length;

    if (empresas.length === 0) {
      list.innerHTML = `
        <div class="p-8 text-center text-slate-400">
          <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <p class="text-sm">Nenhuma empresa encontrada</p>
        </div>`;
      return;
    }

    list.innerHTML = empresas.map((emp, idx) => {
      const distance = (Math.random() * radius).toFixed(2);
      return `
        <div class="radar-result-item p-4 border-b border-slate-800 cursor-pointer">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <h4 class="text-sm font-medium text-white truncate">${emp.nomeFantasia}</h4>
              <p class="text-xs text-slate-400 mt-0.5">${emp.razaoSocial}</p>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-xs text-slate-500 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  ${distance} km
                </span>
              </div>
            </div>
            <button class="px-3 py-1.5 bg-blue-600/20 text-blue-400 rounded-lg text-xs font-medium hover:bg-blue-600/30 transition-colors">
              Contatar
            </button>
          </div>
        </div>
      `;
    }).join('');
  }

  window.getMyLocation = function() {
    const btn = document.getElementById('btn-my-location');
    btn.classList.add('btn-loading');
    
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          userLocation = {
            lat: position.coords.latitude,
            lng: position.coords.longitude
          };
          if (radarMap) {
            radarMap.setView([userLocation.lat, userLocation.lng], 13);
            L.marker([userLocation.lat, userLocation.lng]).addTo(radarMap).bindPopup('Sua localização').openPopup();
          }
          showToast('Localização atualizada com sucesso');
          btn.classList.remove('btn-loading');
        },
        (error) => {
          showToast('Erro ao obter localização', 'error');
          btn.classList.remove('btn-loading');
        }
      );
    } else {
      showToast('Geolocalização não suportada', 'error');
      btn.classList.remove('btn-loading');
    }
  }

  // Inicializa os listeners quando o componente carrega
  document.addEventListener('DOMContentLoaded', () => {
    const btnSearch = document.getElementById('btn-search-prospects');
    const btnMyLocation = document.getElementById('btn-my-location');
    const btnExport = document.getElementById('btn-export-results');

    if (btnSearch) btnSearch.addEventListener('click', window.searchProspects);
    if (btnMyLocation) btnMyLocation.addEventListener('click', window.getMyLocation);
    if (btnExport) btnExport.addEventListener('click', () => showToast('Exportação em breve!'));
  });
</script>