---
const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' }
];

// Detecta a página atual para destacar o link ativo
const currentPath = Astro.url.pathname;
---

<header>
  <h1>🌐 Meu Site Modular (Astro)</h1>
  <nav>
    {navLinks.map(link => (
      <a 
        href={link.href} 
        class={link.href === currentPath ? 'active' : ''}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  header {
    background: #1a1a1a;
    color: #fff;
    padding: 1.5rem;
    text-align: center;
  }
  nav {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    margin-top: 0.75rem;
  }
  nav a {
    color: #4ade80;
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    transition: all 0.2s ease;
  }
  nav a:hover {
    background: rgba(74, 222, 128, 0.1);
    text-decoration: none;
  }
  nav a.active {
    background: #4ade80;
    color: #1a1a1a;
    font-weight: 600;
  }
</style>